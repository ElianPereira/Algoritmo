DATABASE_URL=postgresql://user:pass@host:5432/value_investing
RISK_FREE_RATE=0.045
TAX_RATE_MEX=0.10
COMMISSION_RATE=0.0025
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=86400

# WhatsApp alerts via Twilio (leave blank to disable)
# 1. Sign up at https://www.twilio.com
# 2. Enable WhatsApp Sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# 3. Fill in the values below
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_TO_WHATSAPP=whatsapp:+521234567890
Z_SCORE_ALERT_THRESHOLD=3.0
F_SCORE_ALERT_THRESHOLD=7
